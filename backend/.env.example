PORT=5000
NODE_ENV=development

# Frontend URL. For deploy, use your deployed frontend URL.
# Separate multiple origins with comma, e.g. http://localhost:5173,https://your-frontend.vercel.app
CLIENT_URL=http://localhost:5173

# Public backend URL. Required after deploy so imageUrl points to backend domain.
PUBLIC_API_URL=http://localhost:5000

# FastAPI AI URL
FASTAPI_URL=http://localhost:8000
AI_TIMEOUT_MS=60000
MAX_RECOMMENDATIONS=5
DEFAULT_SKIN_TYPE=Berminyak

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
JSON_LIMIT=10mb

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Local PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=acnedetect_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_SSL=false

# Deploy PostgreSQL alternative
# DATABASE_URL=postgresql://user:password@host:5432/database
